---
import Footer from "../components/Footer.astro";

const {
  title = "Dog House Cafe",
  description = "Real-world infrastructure, systems, debugging, and builder stories.",
} = Astro.props;

const blogBasePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const themeBasePath = `${blogBasePath}styles/`;
---

<!doctype html>
<html lang="en" data-theme="ember">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      id="theme-stylesheet"
      data-theme-link
      rel="stylesheet"
      href={`${themeBasePath}ember.css`}
    />

    <script is:inline>
      const themes = new Set(["ember", "ocean"]);
      const savedTheme = localStorage.getItem("doghouse-theme");
      const initialTheme = themes.has(savedTheme) ? savedTheme : "ember";
      document.documentElement.dataset.theme = initialTheme;
    </script>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="site-logo" href="/">Dog House Cafe</a>

        <nav class="site-nav" aria-label="Main navigation">
          <a href="/">Home</a>
          <a href="/about/">About</a>
          <a href={blogBasePath}>Blog</a>
          <a href={`${blogBasePath}contributors/`}>Contributors</a>
          <a href="https://community.doghouse.cafe">Community</a>
        </nav>

        <div class="theme-switcher">
          <label class="visually-hidden" for="theme-select">Theme</label>
          <select class="theme-select" id="theme-select" data-theme-select>
            <option value="ember">Ember</option>
            <option value="ocean">Ocean</option>
          </select>
        </div>
      </header>
      <main class="site-main">
        <slot />
      </main>

      <Footer />
    </div>
    <script define:vars={{ themeBasePath }} is:inline>
      const themes = new Set(["ember", "ocean"]);
      const savedTheme = localStorage.getItem("doghouse-theme");
      const initialTheme = themes.has(savedTheme) ? savedTheme : "ember";
      const themeLink = document.querySelector("[data-theme-link]");
      const controls = document.querySelectorAll("[data-theme-select]");

      function applyTheme(theme) {
        if (!themes.has(theme)) {
          return;
        }

        document.documentElement.dataset.theme = theme;
        localStorage.setItem("doghouse-theme", theme);

        if (themeLink) {
          themeLink.setAttribute("href", `${themeBasePath}${theme}.css`);
        }

        controls.forEach((control) => {
          control.value = theme;
        });
      }

      controls.forEach((control) => {
        control.addEventListener("change", (event) => {
          applyTheme(event.target.value);
        });
      });

      applyTheme(initialTheme);
    </script>
  </body>
</html>
