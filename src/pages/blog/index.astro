---
import BlogPostCard from "../../components/BlogPostCard.astro";
import { getSortedPosts } from "../../lib/posts";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getSortedPosts();
---

<BaseLayout
  title="Dog House Cafe Blog"
  description="Real-world engineering stories from Dog House Cafe."
>
  <section class="about-hero">
    <h1>Dog House Cafe Blog</h1>
    <p>
      Real-world engineering stories, debugging paths, production failures,
      partial answers, and the messy gap between what should work and what
      actually happens.
    </p>
  </section>

  <section class="blog-list" aria-label="Blog posts">
    {posts.map((post) => <BlogPostCard post={post} />)}
  </section>
</BaseLayout>
