---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolvePeopleImage } from "../../lib/people";

const authors = await getCollection("authors", ({ data, id }) => !data.draft && id !== "guest" && id !== "guest.md");


const groupOrder = ["Founders", "Contributors", "Guests"];

const getAuthorGroup = (author: (typeof authors)[number]) => {
  if (author.data.group) {
    return author.data.group;
  }

  if (author.data.role?.includes("Founder")) {
    return "Founders";
  }
  if (author.data.role?.includes("Contributor")) {
    return "Contributors";
  }
  return "External";
};

const groupedAuthors = groupOrder
  .map((group) => ({
    group,
    authors: authors
      .filter((author) => getAuthorGroup(author) === group)
      .sort((a, b) => {
        const priorityDiff = (a.data.priority ?? 999) - (b.data.priority ?? 999);

        if (priorityDiff !== 0) {
          return priorityDiff;
        }

        return a.data.name.localeCompare(b.data.name);
      }),
  }))
  .filter((group) => group.authors.length > 0);
---

<BaseLayout
  title="Contributors | Doghouse Cafe Blog"
  description="People contributing real-world engineering stories to Doghouse Cafe."
>
  <section class="about-hero">
    <h1>Contributors</h1>
    <p>
      Builders, operators, and practitioners sharing real-world engineering
      stories, debugging paths, and production lessons.
    </p>
  </section>
  {
    groupedAuthors.map(({ group, authors }) => (
      <section class="contributors-group" aria-labelledby={`${group.toLowerCase()}-contributors`}>
        <h2 id={`${group.toLowerCase()}-contributors`}>{group}</h2>

        <div class="contributors-grid">
          {authors.map((author) => {
            const avatarSrc = resolvePeopleImage(author.data.avatar);
            const affiliations = author.data.affiliations?.slice(0, 2) ?? [];

            return (
              <article class="contributor-card">
                {avatarSrc && (
                  <img class="contributor-avatar" src={avatarSrc} alt="" loading="lazy" />
                )}
                <h3>{author.data.name}</h3>
                {author.data.role && <p>{author.data.role}</p>}
                {
                  affiliations.length > 0 && (
                    <ul class="contributor-affiliations" aria-label={`${author.data.name} affiliations`}>
                      {affiliations.map((affiliation) => (
                        <li>{affiliation}</li>
                      ))}
                    </ul>
                  )
                }
                {author.data.link && (
                  <a href={author.data.link} target="_blank" rel="noopener noreferrer">
                    LinkedIn
                  </a>
                )}
              </article>
            );
          })}
        </div>
      </section>
    ))
  }
</BaseLayout>
