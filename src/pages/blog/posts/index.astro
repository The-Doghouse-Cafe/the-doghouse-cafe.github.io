---
import BlogPostCard from "../../../components/BlogPostCard.astro";
import { getSortedPosts } from "../../../lib/posts";
import BaseLayout from "../../../layouts/BaseLayout.astro";

// Posts archive data: newest published posts first.
const posts = await getSortedPosts();
---

<BaseLayout
  title="Posts | Dog House Cafe Blog"
  description="All Dog House Cafe blog posts."
>
  <!-- Archive hero -->
  <section class="about-hero">
    <h1>Posts</h1>
    <p>
      Real-world engineering stories, debugging paths, production failures,
      partial answers, and what actually happens.
    </p>
  </section>

  <!-- Archive list -->
  <section class="blog-list" aria-label="Blog posts">
    {posts.map((post) => <BlogPostCard post={post} />)}
  </section>
</BaseLayout>
