---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPeople, resolvePeopleImage } from "../../lib/people";

export async function getStaticPaths() {
  const people = await getPeople();

  return people
    .filter((person) => person.slug)
    .map((person) => ({
      params: { slug: person.slug },
      props: { person },
    }));
}

const { person } = Astro.props;
const imageSrc = resolvePeopleImage(person.image);
const role = person.roleShort ?? person.role;
const primaryLinks = person.links.filter((link) => link.type === "primary");
const affiliationLinks = person.links.filter((link) => link.type === "affiliation");
const bio = person.bio ?? person.bioShort;
---

<BaseLayout
  title={`${person.name} | Dog House Cafe`}
  description={person.bioShort ?? person.roleShort ?? person.role ?? `${person.name} at Dog House Cafe.`}
>
  <article class="person-profile">

    <header class="person-profile-header">
      {
        imageSrc && (
          <img class="person-profile-avatar" src={imageSrc} alt={person.name} loading="eager" />
        )
      }

      <div>
        <h1>{person.name}</h1>
        {role && <p class="person-profile-role">{role}</p>}
      </div>
    </header>

    {
      person.affiliations.length > 0 && (
        <ul class="person-profile-affiliations" aria-label={`${person.name} affiliations`}>
          {person.affiliations.map((affiliation) => (
            <li>
              {affiliation.href ? (
                <a href={affiliation.href} target="_blank" rel="noopener noreferrer">
                  {affiliation.label}
                </a>
              ) : (
                affiliation.label
              )}
            </li>
          ))}
        </ul>
      )
    }

    {bio && <p class="person-profile-bio">{bio}</p>}

    {
      (primaryLinks.length > 0 || affiliationLinks.length > 0) && (
        <div class="person-profile-links" aria-label={`${person.name} links`}>
          {[...primaryLinks, ...affiliationLinks].map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </article>
  <a class="about-back" href="/people/">Back to People</a>

</BaseLayout>
