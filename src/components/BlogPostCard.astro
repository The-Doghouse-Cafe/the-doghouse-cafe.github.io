---
import type { CollectionEntry } from "astro:content";
import { resolvePostAuthor } from "../lib/authors";
import { resolvePeopleImage } from "../lib/people";
import {
  getNormalizedPostTags,
  getPostDate,
  getPostUpdatedDate,
  getPostUrl,
  shouldDisplayPostUpdatedDate,
} from "../lib/posts";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const formattedDate = getPostDate(post).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const formattedUpdatedDate = getPostUpdatedDate(post)?.toLocaleDateString(
  "en-US",
  {
    month: "long",
    day: "numeric",
    year: "numeric",
  },
);
const showUpdatedDate = shouldDisplayPostUpdatedDate(post);
const teaser = post.data.teaser ?? post.data.description;
const author = await resolvePostAuthor(post.data.author);
const postUrl = getPostUrl(post);
const avatarSrc = resolvePeopleImage(author.avatar);
const tags = getNormalizedPostTags(post);
---

<article class="blog-card">
  <p class="blog-meta">
    Published {formattedDate}
    {
      showUpdatedDate && formattedUpdatedDate
        ? ` · Updated ${formattedUpdatedDate}`
        : ""
    }
  </p>
  <div class="author-byline">
    {
      avatarSrc && (
        <img class="author-avatar" src={avatarSrc} alt="" loading="lazy" />
      )
    }
    <span>
      By {
        author.linkedin ? (
          <a href={author.linkedin} target="_blank" rel="noopener noreferrer">
            {author.name}
          </a>
        ) : (
          <span>{author.name}</span>
        )
      }
    </span>
  </div>
  <h2>
    <a href={postUrl}>{post.data.title}</a>
  </h2>
  <p class="blog-teaser">{teaser}</p>
  <div class="blog-card-footer">
    {
      tags.length > 0 && (
        <ul class="tag-list" aria-label="Post tags">
          {tags.map((tag) => (
            <li data-tag-slug={tag.slug}>{tag.label}</li>
          ))}
        </ul>
      )
    }
    <a class="read-more" href={postUrl}>Read more</a>
  </div>
</article>
