---
import type { CollectionEntry } from "astro:content";

interface Props {
  member: CollectionEntry<"team">;
}

const { member } = Astro.props;
const { name, role, image, bio, links, cardRole } = member.data;
const primaryLinks = links.filter((link) => link.type === "primary");
const affiliationLinks = links.filter((link) => link.type === "affiliation");
const imageSrc = image.startsWith("/") ? image : `/assets/team/${image}`;
const roleLines = role.split("\n");
const isIconAvatar = image.endsWith(".svg");
---

<article class:list={["team-card", cardRole]}>
  <div class="profile-bg"></div>
  <div class="avatar-ring">
    {
      isIconAvatar ? (
        <span class="guest-avatar-icon" role="img" aria-label={name}></span>
      ) : (
        <img class="team-avatar" src={imageSrc} alt={name} />
      )
    }
  </div>

  <h3>{name}</h3>
  <p class="team-role">
    {
      roleLines.map((line, index) => (
        <>
          {index > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <p class="team-bio">{bio}</p>

  {
    affiliationLinks.length > 0 ? (
      <div class="team-links">
        {primaryLinks.map((link) => (
          <a class="team-link" href={link.href} target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
        <div class="team-affiliations">
          {affiliationLinks.map((link) => (
            <a
              class="team-affiliation-link"
              href={link.href}
              target={link.href === "#" ? undefined : "_blank"}
              rel={link.href === "#" ? undefined : "noopener noreferrer"}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    ) : (
      primaryLinks.map((link) => (
        <a class="team-link" href={link.href} target="_blank" rel="noopener noreferrer">
          {link.label}
        </a>
      ))
    )
  }
</article>
