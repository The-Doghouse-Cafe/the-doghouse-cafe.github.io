---
interface Section {
  title: string;
  paragraphs: readonly string[];
}

interface Props {
  hero: Section;
  sections: readonly Section[];
}

const { hero, sections } = Astro.props;
---

<section class="about-hero">
  <h1>{hero.title}</h1>

  {hero.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
</section>

{
  sections.map((section) => (
    <section class="about-section">
      <h2>{section.title}</h2>
      {section.paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </section>
  ))
}
