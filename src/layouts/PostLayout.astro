---
import type { CollectionEntry } from "astro:content";
import { resolvePostAuthor } from "../lib/authors";
import { resolvePeopleImage } from "../lib/people";
import {
  getNormalizedPostTags,
  getPostDate,
  getPostUpdatedDate,
  getPostUrl,
  shouldDisplayPostUpdatedDate,
} from "../lib/posts";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const formattedDate = getPostDate(post).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const formattedUpdatedDate = getPostUpdatedDate(post)?.toLocaleDateString(
  "en-US",
  {
    month: "long",
    day: "numeric",
    year: "numeric",
  },
);
const showUpdatedDate = shouldDisplayPostUpdatedDate(post);
const author = await resolvePostAuthor(post.data.author);
const blogBasePath = "/blog/";
const avatarSrc = resolvePeopleImage(author.avatar);
const tags = getNormalizedPostTags(post);
const canonicalPath = getPostUrl(post);
---

<BaseLayout
  title={`${post.data.title} | Dog House Cafe Blog`}
  description={post.data.description}
  canonicalPath={canonicalPath}
>
  <article class="post-page">
    <header class="post-header">
      <p class="blog-meta">
        Published {formattedDate}
        {
          showUpdatedDate && formattedUpdatedDate
            ? ` · Updated ${formattedUpdatedDate}`
            : ""
        }
      </p>
      <div class="author-byline post-author">
        {
          avatarSrc && (
            <img class="author-avatar" src={avatarSrc} alt="" loading="lazy" />
          )
        }
        <span>
          By {
            author.linkedin ? (
              <a
                href={author.linkedin}
                target="_blank"
                rel="noopener noreferrer"
              >
                {author.name}
              </a>
            ) : (
              <span>{author.name}</span>
            )
          }
          {author.role && <span> · {author.role}</span>}
        </span>
      </div>
      <h3>{post.data.title}</h3>

      {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Post tags">
            {tags.map((tag) => (
              <li data-tag-slug={tag.slug}>{tag.label}</li>
            ))}
          </ul>
        )
      }
    </header>
    {post.data.description && <p>{post.data.description}</p>}
    <div class="post-content">
      <slot />
    </div>
  </article>
  <footer class="post-footer">
    <a class="about-back" href={blogBasePath}>Back to Blog</a>
  </footer>
</BaseLayout>
